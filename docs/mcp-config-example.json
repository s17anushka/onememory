{
  "mcpServers": {
    "onememory-claude-code": {
      "command": "node",
      "args": ["/absolute/path/to/onememory/mcp-server/dist/index.js"],
      "env": {
        "COCKROACH_DATABASE_URL": "postgresql://<user>:<password>@<host>:26257/onememory?sslmode=verify-full",
        "ONEMEMORY_SOURCE_TOOL": "claude-code"
      }
    },
    "onememory-cursor": {
      "command": "node",
      "args": ["/absolute/path/to/onememory/mcp-server/dist/index.js"],
      "env": {
        "COCKROACH_DATABASE_URL": "postgresql://<user>:<password>@<host>:26257/onememory?sslmode=verify-full",
        "ONEMEMORY_SOURCE_TOOL": "cursor"
      }
    }
  }
}
